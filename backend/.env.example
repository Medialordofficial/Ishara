# Ishara Backend Environment Variables
# Copy this file to .env and fill in your values

# API authentication key (leave empty to disable auth)
ISHARA_API_KEY=

# Rate limiting: max requests per minute per IP (default: 30)
ISHARA_RATE_LIMIT=30

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Gemma model name as configured in Ollama.
# Production / Colab demo uses gemma4:latest (the latest Gemma).
# For low-RAM local dev where 8B doesn't fit, fall back to gemma3:4b.
ISHARA_MODEL=gemma4:latest
ISHARA_FAST_MODEL=gemma4:latest
ISHARA_FULL_MODEL=gemma4:latest

# Per-request LLM timeout in seconds (default: 300).
# Raise for slow hardware or large models.
ISHARA_OLLAMA_TIMEOUT=300

# CORS allowed origins (comma-separated, default: *)
# For production, restrict to your app's IP:
# ISHARA_CORS_ORIGINS=http://192.168.1.100:8000,http://your-server:8000
ISHARA_CORS_ORIGINS=*

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
